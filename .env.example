# Copy this file to .env and edit values as needed.
# Python-dotenv will load it automatically when running locally.

FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000
SECRET_KEY=change-me-to-a-random-string

# Detection
CONF_THRESH=0.40
IOU_THRESH=0.45
INFER_SIZE=640

# Video output
FRAME_WIDTH=640
FRAME_HEIGHT=480
JPEG_QUALITY=80
STREAM_FPS=30

# Tracking
MAX_DISAPPEARED=30
